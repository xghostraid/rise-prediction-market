# Copy to .env.local (must be the FILENAME .env.local — not the variable name):
#   cp env.example .env.local
# Set NEXT_PUBLIC_MARKET_FACTORY to the MarketFactory *contract* address from deploy logs
# ("MarketFactory: 0x…"), not the same as your wallet / deployer EOA.
#
# Dev server (npm run dev) listens on http://127.0.0.1:3010 — use that URL in the browser.
#
# Vercel: set Root Directory to `web`, then add the same NEXT_PUBLIC_* variables in
# Project → Settings → Environment Variables. See ../VERCEL.md in the repo root.

NEXT_PUBLIC_MARKET_FACTORY=0xYourDeployedMarketFactory
NEXT_PUBLIC_RISE_RPC=https://testnet.riselabs.xyz
# Optional: ETH-only order book markets (CLOB).
# NEXT_PUBLIC_ORDERBOOK_FACTORY=0xYourDeployedOrderBookFactory
# Optional: run the `indexer/` service and point the UI at it for full history (no RPC limits).
# Example: http://127.0.0.1:4090
# NEXT_PUBLIC_INDEXER_URL=
# Leave blank for local dev (injected wallets only, no Reown allowlist).
# If set: add every origin you use (e.g. http://127.0.0.1:3010) at https://cloud.reown.com
# NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
